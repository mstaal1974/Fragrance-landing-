# Environment variables for the Maison Obsidian storefront. Set these in your
# Vercel project → Settings → Environment Variables (tick the Production env).
# Never commit real values.

# ── Stripe (checkout) ─────────────────────────────────────────────────────
# Read by api/checkout.js and api/order.js. Card details are entered on
# Stripe's hosted checkout page, so they never touch this site.

# Required — your Stripe secret key. Use a test key (sk_test_…) until you go live.
STRIPE_SECRET_KEY=

# Optional — ISO currency code for prices. Defaults to "aud".
STRIPE_CURRENCY=aud

# Optional — absolute origin for the success/cancel return URLs. Defaults to the
# request's own origin, so you normally don't need this. Set it only to force a
# canonical domain (e.g. https://drop.maisonobsidian.com).
STRIPE_RETURN_ORIGIN=

# ── Australia Post PAC (shipping) ─────────────────────────────────────────
# Read by api/shipping.js and api/checkout.js. Get a key at
# https://developers.auspost.com.au/ . Server-side only.

# Required for live shipping rates — the PAC key sent as the AUTH-KEY header.
AUSPOST_API_KEY=

# Optional — the postcode parcels are dispatched from. Defaults to 3000 (Melbourne).
AUSPOST_FROM_POSTCODE=3000
