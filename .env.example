# Australia Post PAC (Postage Assessment Calculator) — read by api/shipping.js.
# Get a key at https://developers.auspost.com.au/ and set these in your Vercel
# project (Settings → Environment Variables). Never commit real values.

# Required — the PAC API key sent as the AUTH-KEY header. Server-side only.
AUSPOST_API_KEY=

# Optional — the postcode parcels are dispatched from. Defaults to 3000 (Melbourne).
AUSPOST_FROM_POSTCODE=3000
